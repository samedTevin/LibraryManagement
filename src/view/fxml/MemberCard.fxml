<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="250.0" prefWidth="180.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MemberCardController">
   <children>
      <ImageView fx:id="memberImage" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../assets/placeholder_member.png" />
         </image>
      </ImageView>
      <VBox prefHeight="100.0" prefWidth="100.0" spacing="5.0">
         <children>
            <Label fx:id="memberId" text="#ID" textFill="#999999">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label fx:id="memberName" prefHeight="31.0" prefWidth="161.0" text="John Doe">
               <font>
                  <Font name="Berlin Sans FB Bold" size="16.0" />
               </font>
            </Label>
            <Label fx:id="memberEmail" prefHeight="31.0" prefWidth="161.0" text="john@example.com">
               <font>
                  <Font name="Berlin Sans FB" size="14.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
